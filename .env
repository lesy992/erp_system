# ==========================================
# 1. 공통 데이터베이스 설정
# ==========================================
# MySQL root 계정 비밀번호 (실제 운영 수준의 복잡한 비밀번호로 변경하세요)
MYSQL_ROOT_PASSWORD=lsy749200!

# ==========================================
# 2. Auth Service (인증 서비스) DB 설정
# ==========================================
# auth-db 컨테이너에서 생성할 데이터베이스 이름
AUTH_DB_NAME=auth_db
# 로컬 PC에서 auth-db에 접속할 때 사용할 포트 (3306 충돌 방지)
AUTH_DB_PORT=3307

# ==========================================
# 3. Biz Service (비즈니스 서비스) DB 설정
# ==========================================
# biz-db 컨테이너에서 생성할 데이터베이스 이름
BIZ_DB_NAME=biz_db
# 로컬 PC에서 biz-db에 접속할 때 사용할 포트
BIZ_DB_PORT=3308

# ==========================================
# 4. Spring Boot 공통 프로필 (선택사항)
# ==========================================
# 로컬 개발 환경임을 명시
SPRING_PROFILES_ACTIVE=local